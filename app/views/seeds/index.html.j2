{% extends layout('panel.html.j2') %}

{% block content %}
<div class="flex flex-col gap-8 px-8 py-12">
    <div class="flex items-center">
        <div class="flex-1 flex items-end gap-6">
            <h2 class="text-2xl font-bold">Seeds</h2>
            <p class="text-zinc-500 text-base"><span>{{seeds | length }} Seeds</span>&nbsp;&middot;&nbsp;<span>{{
                    schemas | length }} Schemas</span></p>
        </div>
        <form method="get" action="/seeds/" class="flex items-center gap-2" x-data x-ref="sortBy">
            <label for="sortBy" class="block w-max shrink-0">Sort by:</label>
            <select name="sortBy" id="sortBy"
                class="px-2 border-none outline-2 outline-transparent rounded focus:outline-blue-500 duration-150 w-max min-w-24 cursor-pointer"
                x-on:change="$refs.sortBy.submit()">
                <option value="recent">Recent</option>
                <option value="name">Name</option>
            </select>
        </form>
    </div>
    <section class="grid gap-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5">
        {% for seed in seeds %}
        <div class="flex flex-col gap-4 p-4 rounded-lg border border-zinc-600 bg-zinc-800">
            <div>
                <h3 class="text-xl font-semibold">{{ seed.name }}</h3>
                <span class="text-zinc-500">
                    {% set schema_count = schemas[seed._id] | length %}
                    {{ schema_count }}
                    {% if schema_count is equalto 1 %}
                    schema
                    {% else %}
                    schemas
                    {% endif %}
                </span>
            </div>
            <div class="flex-1 flex flex-col gap-2">
                {% for schema in schemas[seed._id][:3] %}
                <div class="w-full flex items-center border border-zinc-500 px-4 py-2 bg-zinc-700/40 rounded-md">
                    <div class="flex items-center gap-4 flex-1">
                        <i class="bi bi-braces text-zinc-500"></i>
                        <h4 class="text-lg">{{schema.name}}</h4>
                    </div>
                </div>
                {% endfor %}
                {% if schema_count > 3 %}
                <div class="w-full flex items-center border border-zinc-700 px-4 py-2 bg-zinc-700/80 rounded-md">
                    <div class="flex items-center gap-4 flex-1">
                        <i class="bi bi-braces text-zinc-700"></i>
                        <h4 class="text-lg text-zinc-200">{{schema.name}}</h4>
                    </div>
                </div>
                {% endif %}
            </div>
            <div class="flex items-center">
                <div class="flex-1">
                    {% if schema_count > 4 %}
                    <span class="text-zinc-500">
                        + {{ schema_count - 4 }} more {% if schema_count == 5 %}schema{% else %}schemas{% endif %}
                    </span>
                    {% else %}
                    &nbsp;
                    {% endif %}
                </div>
                <div class="flex items-center gap-4">
                    <a href="/seeds/{{ seed.slug }}" class="btn btn-ghost">Open</a>
                    <a class="btn btn-primary">Generate</a>
                </div>
            </div>
        </div>
        {% endfor %}
        <button 
            class="flex flex-col gap-4 p-4 rounded-lg border border-dashed border-zinc-600 bg-zinc-800/50 hover:bg-zinc-800/85 duration-150" 
            popovertarget="new_seed" 
            popovertargetaction="show"
        >
            <div class="flex-1 flex flex-col justify-center items-center gap-4">
                <i class="bi bi-plus-lg text-2xl p-2 border border-zinc-600 text-zinc-500 rounded-lg"></i>
                <div class="space-y-2">
                    <h4 class="text-zinc-200 text-center">New Seed</h4>
                    <p class="text-zinc-500">Create a new schema collection</p>
                </div>
            </div>
        </button>
    </section>
</div>
{% endblock %}