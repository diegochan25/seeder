{% from macro('option_picker.html.j2') import option_picker %}
{% extends layout('seed.html.j2') %}

{% block tab %}
<div class="flex flex-col flex-1 gap-8" x-data="{ showForm: false }">
<form id="newField" x-ref="newField" method="post" action="/seeds/{{ seed.slug }}/schemas/{{ schema.slug }}/fields" class="hidden"></form>
<div>
    <span class="text-sm text-zinc-500 uppercase">schema</span>
    <h2 class="text-2xl font-bold">{{ schema.name }}</h2>
</div>
<div class="flex-1 w-full overflow-x-auto">
    <table class="w-full border-separate border-spacing-x-0 border-spacing-y-2">
        <caption class="text-left text-zinc-500 uppercase font-semibold">Schema fields</caption>
        <thead>
            <tr>
                <th class="text-sm text-left text-zinc-500 uppercase px-4 py-1">Field</th>
                <th class="text-sm text-left text-zinc-500 uppercase px-4 py-1">Generator</th>
                <th class="text-sm text-left text-zinc-500 uppercase px-4 py-1">Options</th>
                <th class="text-sm text-left text-zinc-500 uppercase px-4 py-1">&nbsp;</th>
            </tr>
        </thead>
        <tbody>
            {% for field in fields %}
                <tr class="rounded-lg overflow-hidden bg-zinc-800/75">
                    <td class="border-y first:border-l first:rounded-l-lg last:border-r last:rounded-r-lg border-zinc-600 px-4 py-3">
                        <p class="text-attr-blue">{{ field.name }}</p>
                    </td>
                    <td class="border-y first:border-l first:rounded-l-lg last:border-r last:rounded-r-lg border-zinc-600 px-4 py-3">
                        <div class="relative">
                            <p class="text-value-salmon">{{ field.generator_label }}</p>
                        </div>
                    </td>
                    <td class="border-y first:border-l first:rounded-l-lg last:border-r last:rounded-r-lg border-zinc-600 px-4 py-3">
                        <div class="relative">
                            <p class="text-value-salmon">View options (stub)</p>
                        </div>
                    </td>
                    <td class="border-y first:border-l first:rounded-l-lg last:border-r last:rounded-r-lg border-zinc-600 px-4 py-3">
                        <button
                            class="flex items-center gap-1 link link-error"
                            x-on:click="fetch('/seeds/{{ seed.slug }}/schemas/{{ schema.slug }}/fields/{{ field._id }}', { method: 'DELETE' }).then(() => location.reload())"
                        >
                            <i class="bi bi-x"></i>
                            Delete
                        </button>                        
                    </td>
                </tr>            
            {% else %}
                <tr class="rounded-lg overflow-hidden bg-zinc-800/75">
                    <td colspan="9999" class="border rounded-lg border-zinc-600 px-4 py-3 text-zinc-500 text-center italic">
                        This schema has no fields.
                    </td>
                </tr>        
            {% endfor %}
            <tr class="rounded-lg overflow-hidden bg-zinc-800/75" x-show="showForm">
                 <td class="border-y first:border-l first:rounded-l-lg last:border-r last:rounded-r-lg border-zinc-600 px-4 py-3">
                    <input
                        type="text"
                        form="newField"
                        name="name"
                        id="fieldName"
                        placeholder="field name"
                        class="px-2 py-1 rounded-lg w-2xs border border-zinc-600 outline-2 outline-transparent hover:outline-blue-500 duration-150 placeholder:italic"
                    >
                </td>
                <td class="border-y first:border-l first:rounded-l-lg last:border-r last:rounded-r-lg border-zinc-600 px-4 py-3">
                    <div class="relative">
                        {% include partial('_generator_picker.html.j2') %}
                    </div>
                </td>   
                <td class="border-y first:border-l first:rounded-l-lg last:border-r last:rounded-r-lg border-zinc-600 px-4 py-3">
                    <div class="relative">
                        {{ option_picker([]) }}
                    </div>
                </td>  
                <td class="border-y first:border-l first:rounded-l-lg last:border-r last:rounded-r-lg border-zinc-600 px-4 py-3">
                    <input type="submit" value="Add field" class="btn btn-primary" form="newField">
                </td>      
            </tr>
            <tr class="rounded-lg overflow-hidden bg-zinc-800/75">
                 <td class="border-y first:border-l first:rounded-l-lg last:border-r last:rounded-r-lg border-zinc-600 px-4 py-3">
                    <input
                        type="text" 
                        form="newField" 
                        name="fieldName" 
                        id="fieldName"
                        placeholder="field name"
                        class="px-2 py-1 rounded-lg w-2xs border border-zinc-600 outline-2 outline-transparent hover:outline-blue-500 duration-150 placeholder:italic"
                    >
                </td>
                <td class="border-y first:border-l first:rounded-l-lg last:border-r last:rounded-r-lg border-zinc-600 px-4 py-3">
                    <label class="custom-select">
                        <input type="checkbox" id="select-opener" class="hidden">
                        <span id="selected-content">&nbsp;</span>
                    </label>
                </td>
                <td class="border-y first:border-l first:rounded-l-lg last:border-r last:rounded-r-lg border-zinc-600 px-4 py-3">
                </td>           
            </tr>
        </tbody>
        <tfoot>
            <tr>
                <td colspan="9999">
                    <button
                        class="w-full flex justify-center items-center gap-4 border border-dashed border-zinc-500 text-zinc-500 p-3 rounded-lg hover:bg-zinc-800/75 duration-150"
                        x-on:click="showForm = !showForm; $refs.newField.reset();"
                    >
                        <div class="contents" x-show="!showForm">
                            <i class="bi bi-plus-lg"></i>
                            Add a field
                        </div>
                        <div class="contents" x-show="showForm">
                            <i class="bi bi-x-lg"></i>
                            Cancel
                        </div>
                    </button>
                </td>
            </tr>
        </tfoot>
    </table>
</div>
</div>
{% endblock %}