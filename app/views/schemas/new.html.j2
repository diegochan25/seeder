{% extends layout('seed.html.j2') %}

{% block tab %}
<div>
    <span class="text-sm text-zinc-500 uppercase">initialize</span>
    <h2 class="text-2xl font-bold">New Schema</h2>
</div>
<form method="post" action="/seeds/{{ seed.slug }}/schemas/" class="rounded-lg overflow-hidden w-full max-w-2xl space-y-4 bg-zinc-800/75 border border-zinc-600 px-4 py-3">
    <div class="flex items-end gap-6">
        <div class="flex-1 space-y-1">
            <label for="name" class="block text-sm font-bold uppercase">Schema name</label>
            <input 
                type="text" 
                name="name" 
                id="name"
                class="w-full border border-zinc-500 rounded-md outline-2 outline-transparent focus:outline-blue-500 duration-150 px-2 py-1"
            >
        </div>
        <input type="submit" value="Create schema" class="btn btn-primary">
    </div>
    <div>
        <p class="text-sm text-zinc-400">
            Schemas are groups of fields identifiable by their names.
            While they're considered Seeder's primary feature, they
            don't hold much data of their own.
        </p>
    </div>
</form>
{% endblock %}