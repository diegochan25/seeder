{% from macro('tooltip.html.j2') import tooltip %}
{% extends layout('panel.html.j2') %}

{% block content %}
<div class="flex flex-col">
    {% set entity = request.url.path.split('/')[-2] %}
    {% set active = request.url.path.split('/')[-1] %}
    <nav class="w-full flex items-center border-b border-zinc-600">
        {% for schema in schemas %}
            <a
                href="/seeds/{{ seed.slug }}/schemas/{{ schema.slug }}"
                class="px-6 pb-2 pt-2.5 border-b-2 {%if entity == 'schemas' and active == schema.slug%}border-yellow-400 bg-yellow-400/10{%else%}border-transparent{%endif%}"
            >{{ schema.name }}</a>
        {% endfor %}
        {% call tooltip('New schema', 'bottom') %}
        <a 
            href="/seeds/{{ seed.slug }}/schemas/new" 
            class="px-6 pb-2 pt-2.5 border-b-2 {%if entity == 'schemas' and active == 'new'%}border-yellow-400 bg-yellow-400/10{%else%}border-transparent{%endif%}"
        >
            <i class="bi bi-plus-lg"></i>
        </a>
        {% endcall %}
        {% call tooltip('Seed options', 'bottom') %}
        <a 
            href="/seeds/{{ seed.slug }}" 
            class="px-6 pb-2 pt-2.5 border-b-2 {%if entity == 'seeds'%}border-yellow-400 bg-yellow-400/10{%else%}border-transparent{%endif%}"
        >
            <i class="bi bi-three-dots-vertical"></i>
        </a>
        {% endcall %}
    </nav>
    <div class="p-8 flex flex-col gap-8">
    {% block tab %}
    {% endblock %}
    </div>
</div>
{% endblock %}